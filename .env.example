
# MindHubs AI Studio Keys Configuration
# Copiez ce fichier en '.env' et remplissez vos clés privées.
# IMPORTANT: Ne jamais pousser le fichier '.env' sur GitHub.

# --- INFRASTRUCTURE ---
VITE_SUPABASE_URL=votre_url_supabase
VITE_SUPABASE_ANON_KEY=votre_cle_anon_supabase

# --- VIDEO AI (fal.ai) ---
# Utilisé pour Kling 1.5, Minimax, Luma, Seedance, etc.
VITE_FAL_KEY=votre_cle_fal_ai

# --- AVATAR AI (HeyGen) ---
# Utilisé pour l'Expert Virtuel (Avatars animés)
VITE_HEYGEN_API_KEY=votre_cle_heygen

# --- VOICE AI (ElevenLabs) ---
# Utilisé pour la narration ultra-réaliste
VITE_ELEVENLABS_API_KEY=votre_cle_elevenlabs
